rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Helper function to check if user document exists
    function userExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }
    
    // Helper function to get user data safely
    function getUserData() {
      return userExists() ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data : null;
    }
    
    // Helper function to check if user is admin
    function isAdmin() {
      return isSignedIn() && userExists() && getUserData().role == 'admin';
    }
    
    // Helper function to check if user is master
    function isMaster() {
      return isSignedIn() && userExists() && getUserData().role == 'master';
    }
    
    // Helper function to check if user is HOD of specific department
    function isHODOfDepartment(department) {
      return isSignedIn() && 
             userExists() &&
             getUserData().role == 'hod' && 
             getUserData().department == department;
    }
    
    // Users collection - only admins can read/write
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }
    
    // eMoU records collection
    match /emous/{emouId} {
      // Anyone authenticated can read
      allow read: if isSignedIn();
      
      // Create: Any authenticated user can create
      allow create: if isSignedIn() && 
                      request.resource.data.createdBy == request.auth.uid;
      
      // Update: Admin can update anything, Master can update anything,
      // HOD can update only their department's records
      allow update: if isSignedIn() && (
                        isAdmin() ||
                        isMaster() ||
                        isHODOfDepartment(resource.data.department)
                      );
      
      // Delete: Only admins can delete
      allow delete: if isAdmin();
    }
    
    // Counters collection - read by all authenticated, write during eMoU creation
    match /counters/{counterId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
  }
}
